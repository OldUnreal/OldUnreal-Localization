[ONSOnslaughtGame]
; EN: ONSPropsDisplayText[0]="Core Drain in Overtime"
ONSPropsDisplayText[0]="Drenatge del nucli en hores extres"
; EN: ONSPropsDisplayText[1]="Random Link Setup After Reset"
